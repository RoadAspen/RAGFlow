{
	"compilerOptions": {
		// 基础配置
		"target": "ES2020",
		"module": "CommonJS",
		"strict": true,
		"moduleResolution": "Bundler", // 现代 monorepo 必备
		"esModuleInterop": true, // 兼容 import / require
		"skipLibCheck": true // 不检查 node_modules 类型
	},
	// 排除 node_modules
	"exclude": ["node_modules", "**/dist", "**/build"]
}
